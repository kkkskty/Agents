# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rule_clauses

# Elasticsearch (BM25 primary retrieval)
ES_URL=http://127.0.0.1:9200
ES_API_KEY=
ES_INDEX=rule_clauses

# Source markdown
MARKDOWN_PATH=D:\AICODE\data\seed\test.md

# Rule metadata
RULE_CODE=RULE-TEST-001
RULE_TITLE=测试规则文档
TENANT_ID=default_tenant
REGION=cn
PRODUCT_LINE=default_product
BIZ_DOMAIN=rules
RULE_STATUS=active
EFFECTIVE_FROM=2026-01-01T00:00:00+00:00
EFFECTIVE_TO=

# Ollama embedding
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=nomic-embed-text-v2-moe
EMBEDDING_MODEL_VERSION=local-manifest

# Lifecycle
KEEP_ONLINE_VERSIONS=2

# Chunking
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_CHARS=250
