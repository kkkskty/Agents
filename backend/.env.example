# Service config
SERVICE_NAME=multi-agent-customer-service
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSIONS_PERSISTENCE=false
GRAPH_DEBUG_TRACE_ENABLED=false
HANDOFF_ENABLED=false
MAX_HISTORY_TURNS=20
NODE_TIMEOUT_MS=8000
MAX_SUB_TASKS=5
INTENT_CONFIDENCE_THRESHOLD=0.65

# Ollama HTTP（默认本机 11434；与 Ollama 安装目录无关）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_HTTP_TIMEOUT=600
# Ollama 深度思考/推理：true 开启（更慢），false 关闭（默认，推荐）。可按智能体覆盖，如 INTENT_AGENT_OLLAMA_REASONING=true
OLLAMA_REASONING=false
LLM_INVOKE_TIMEOUT_S=300
LLM_INVOKE_RETRIES=2
# 若某智能体需单独指向其它 Ollama 实例，可取消注释并设置：
# INTENT_AGENT_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Intent Agent LLM
INTENT_AGENT_USE_LOCAL=true
INTENT_AGENT_LOCAL_LLM_MODEL=qwen2.5:7b
INTENT_AGENT_CLOUD_LLM_MODEL=gpt-4o-mini
INTENT_AGENT_CLOUD_LLM_API_KEY=
INTENT_AGENT_CLOUD_LLM_BASE_URL=
INTENT_AGENT_LLM_TEMPERATURE=0.1

# Search Agent LLM
SEARCH_AGENT_USE_LOCAL=true
SEARCH_AGENT_LOCAL_LLM_MODEL=qwen2.5:7b
SEARCH_AGENT_CLOUD_LLM_MODEL=gpt-4o-mini
SEARCH_AGENT_CLOUD_LLM_API_KEY=
SEARCH_AGENT_CLOUD_LLM_BASE_URL=
SEARCH_AGENT_LLM_TEMPERATURE=0.1

# RAG Agent LLM
RAG_AGENT_USE_LOCAL=true
RAG_AGENT_LOCAL_LLM_MODEL=qwen2.5:7b
RAG_AGENT_CLOUD_LLM_MODEL=gpt-4o-mini
RAG_AGENT_CLOUD_LLM_API_KEY=
RAG_AGENT_CLOUD_LLM_BASE_URL=
RAG_AGENT_LLM_TEMPERATURE=0.1

# Summarizer Agent LLM
SUMMARIZER_AGENT_USE_LOCAL=true
SUMMARIZER_AGENT_LOCAL_LLM_MODEL=qwen2.5:7b
SUMMARIZER_AGENT_CLOUD_LLM_MODEL=gpt-4o-mini
SUMMARIZER_AGENT_CLOUD_LLM_API_KEY=
SUMMARIZER_AGENT_CLOUD_LLM_BASE_URL=
SUMMARIZER_AGENT_LLM_TEMPERATURE=0.1

# RAG config（与 AICODE 对齐：同一 persist 路径、同一 collection、同一 /v1/embeddings）
CHROMA_PATH=D:\AICODE\data\chroma
RAG_COLLECTION_NAME=aicode_kb
RAG_TOP_K=3
RAG_EMBEDDING_MODEL=text-embedding-3-small
# Embeddings API 根地址（须含 /v1，与 AICODE OPENAI_BASE_URL / LLM_BASE_URL 一致时可共用）
RAG_EMBEDDING_BASE_URL=
# OPENAI_BASE_URL=
# LLM_BASE_URL=
# Key 依次尝试：RAG_EMBEDDING_API_KEY、OPENAI_API_KEY、LLM_API_KEY、CHROMA_OPENAI_API_KEY、RAG_AGENT_CLOUD_LLM_API_KEY
RAG_EMBEDDING_API_KEY=
OPENAI_API_KEY=
LLM_API_KEY=

# Mock tools config
MOCK_ORDER_BASE_URL=https://mock-order.local

# MySQL query tool
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=shop
SQL_MAX_ROWS=50
