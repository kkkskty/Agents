SERVICE_NAME=multi-agent-customer-service
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSIONS_PERSISTENCE=false
GRAPH_DEBUG_TRACE_ENABLED=true
HANDOFF_ENABLED=false
MAX_HISTORY_TURNS=20
NODE_TIMEOUT_MS=8000
MAX_SUB_TASKS=5
INTENT_CONFIDENCE_THRESHOLD=0.65

# Ollama：程序若装在 D:\software\ollma，仍通过 HTTP 访问；默认 http://127.0.0.1:11434（可先执行 ollama serve）
OLLAMA_BASE_URL=http://127.0.0.1:11434
# 长对话/多节点会多次调用 LLM：拉大 httpx 与线程等待，并对 502 等瞬时错误重试
OLLAMA_HTTP_TIMEOUT=600
# 关闭 Ollama 深度思考（reasoning），加快本地模型响应；需要时再设为 true
OLLAMA_REASONING=false
LLM_INVOKE_TIMEOUT_S=300
LLM_INVOKE_RETRIES=2

#
#LLM_MODEL_ID=qwen3.5-plus
#LLM_API_KEY=sk-ac9ec4fae2de4ac9bee1b640a6e3c9bd
#LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1



#智能体参数（Ollama：USE_LOCAL=true，并确保 ollama pull 过 LOCAL_LLM_MODEL）
INTENT_AGENT_USE_LOCAL=true
INTENT_AGENT_LOCAL_LLM_MODEL=qwen3.5:4b
# INTENT_AGENT_CLOUD_LLM_MODEL=coding-glm-4.7-free
# INTENT_AGENT_CLOUD_LLM_API_KEY=sk-2gBSVJ4cFHEMBHGI74D142C0405c4f559f91A22dFfCc3a4b
# INTENT_AGENT_CLOUD_LLM_BASE_URL=https://aihubmix.com/v1
INTENT_AGENT_CLOUD_LLM_MODEL=qwen3.5-plus
INTENT_AGENT_CLOUD_LLM_API_KEY=sk-2d2a2505d19247748fb12a1ab6d9879f
INTENT_AGENT_CLOUD_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTENT_AGENT_LLM_TEMPERATURE=0.1

SEARCH_AGENT_USE_LOCAL=true
SEARCH_AGENT_LOCAL_LLM_MODEL=qwen3.5:4b
#SEARCH_AGENT_CLOUD_LLM_MODEL=coding-glm-4.7-free
#SEARCH_AGENT_CLOUD_LLM_API_KEY=sk-2gBSVJ4cFHEMBHGI74D142C0405c4f559f91A22dFfCc3a4b
#SEARCH_AGENT_CLOUD_LLM_BASE_URL=https://aihubmix.com/v1
SEARCH_AGENT_CLOUD_LLM_MODEL=qwen3.5-plus
SEARCH_AGENT_CLOUD_LLM_API_KEY=sk-2d2a2505d19247748fb12a1ab6d9879f
SEARCH_AGENT_CLOUD_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SEARCH_AGENT_LLM_TEMPERATURE=0.1

#RAG_AGENT_USE_LOCAL=false
#RAG_AGENT_LOCAL_LLM_MODEL=qwen2.5:7b
#RAG_AGENT_CLOUD_LLM_MODEL=coding-glm-4.7-free
#RAG_AGENT_CLOUD_LLM_API_KEY=sk-2gBSVJ4cFHEMBHGI74D142C0405c4f559f91A22dFfCc3a4b
#RAG_AGENT_CLOUD_LLM_BASE_URL=https://aihubmix.com/v1
#RAG_AGENT_LLM_TEMPERATURE=0.1

SUMMARIZER_AGENT_USE_LOCAL=true
SUMMARIZER_AGENT_LOCAL_LLM_MODEL=qwen3.5:4b
#SUMMARIZER_AGENT_CLOUD_LLM_MODEL=coding-glm-4.7-free
#SUMMARIZER_AGENT_CLOUD_LLM_API_KEY=sk-2gBSVJ4cFHEMBHGI74D142C0405c4f559f91A22dFfCc3a4b
#SUMMARIZER_AGENT_CLOUD_LLM_BASE_URL=https://aihubmix.com/v1
SUMMARIZER_AGENT_CLOUD_LLM_MODEL=qwen3.5-plus
SUMMARIZER_AGENT_CLOUD_LLM_API_KEY=sk-2d2a2505d19247748fb12a1ab6d9879f
SUMMARIZER_AGENT_CLOUD_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SUMMARIZER_AGENT_LLM_TEMPERATURE=0.1


#RAG参数（Embeddings 与 AICODE addrag 同源：单独配置，勿依赖各 *_AGENT_* 变量）
CHROMA_PATH=D:\AICODE\data\chroma
RAG_TOP_K=3
RAG_EMBEDDING_MODEL=text-embedding-3-small
# 与 D:\AICODE\.env 中 LLM_BASE_URL / LLM_API_KEY 保持一致（settings 解析顺序：先 RAG_EMBEDDING_*，再 OPENAI_*，再 LLM_*）
OPENAI_BASE_URL=https://aihubmix.com/v1
OPENAI_API_KEY=sk-2gBSVJ4cFHEMBHGI74D142C0405c4f559f91A22dFfCc3a4b


MOCK_ORDER_BASE_URL=https://mock-order.local
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=shop
SQL_MAX_ROWS=50





LLM_RESPONSE_LOG_ENABLED=true
